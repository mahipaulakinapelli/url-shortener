# Copy this file to .env and fill in the values before running.

# Database
DB_HOST=localhost
DB_PORT=5432
DB_NAME=urlshortener
DB_USERNAME=postgres
DB_PASSWORD=change_me

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT  – must be a Base64-encoded secret of at least 256 bits (32 bytes)
# Generate with:  openssl rand -base64 32
JWT_SECRET=replace_with_your_base64_secret
JWT_ACCESS_EXPIRY=900000      # 15 minutes in ms
JWT_REFRESH_EXPIRY=604800000  # 7 days in ms

# Application
PORT=8080
BASE_URL=http://localhost:8080
CACHE_URL_TTL=3600